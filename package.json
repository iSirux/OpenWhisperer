{
    "name": "open-whisperer",
    "version": "1.0.0",
    "description": "Voice-controlled interface for Claude Code",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "tauri": "tauri",
        "sidecar:install": "cd src-tauri/sidecar && npm install",
        "sidecar:build": "cd src-tauri/sidecar && npm run build",
        "tauri:dev": "npm run sidecar:build && tauri dev --config src-tauri/tauri.dev.conf.json",
        "tauri:build": "npm run sidecar:build && tauri build"
    },
    "license": "SEE LICENSE IN LICENSE",
    "dependencies": {
        "@tauri-apps/api": "2.11.1",
        "@tauri-apps/plugin-clipboard-manager": "2.3.2",
        "@tauri-apps/plugin-dialog": "2.4.2",
        "@tauri-apps/plugin-global-shortcut": "2.3.1",
        "@tauri-apps/plugin-notification": "2.3.3",
        "@tauri-apps/plugin-opener": "2.5.2",
        "@tauri-apps/plugin-process": "2.3.1",
        "@tauri-apps/plugin-shell": "2.3.3",
        "@tauri-apps/plugin-updater": "2.10.1",
        "@xyflow/svelte": "1.5.1",
        "highlight.js": "11.11.1",
        "marked": "15.0.12",
        "marked-highlight": "2.2.3",
        "paneforge": "1.0.2",
        "tauri-plugin-keyring-api": "0.1.1"
    },
    "devDependencies": {
        "@sveltejs/adapter-static": "3.0.10",
        "@sveltejs/kit": "2.49.0",
        "@sveltejs/vite-plugin-svelte": "5.1.1",
        "@tailwindcss/forms": "0.5.10",
        "@tailwindcss/postcss": "4.1.17",
        "@tauri-apps/cli": "2.11.4",
        "@types/node": "26.1.1",
        "autoprefixer": "10.4.22",
        "postcss": "8.5.6",
        "svelte": "5.45.3",
        "svelte-check": "4.3.4",
        "tailwindcss": "4.1.17",
        "typescript": "5.6.3",
        "vite": "6.4.1"
    }
}
