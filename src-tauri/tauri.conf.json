{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "OpenWhisperer",
    "version": "1.6.0",
    "identifier": "com.isirux.open-whisperer",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build && npm run sidecar:build",
        "frontendDist": "../build"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "OpenWhisperer",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "decorations": true,
                "transparent": false
            },
            {
                "label": "overlay",
                "title": "Recording",
                "url": "/overlay",
                "width": 380,
                "height": 140,
                "center": false,
                "decorations": false,
                "transparent": false,
                "alwaysOnTop": true,
                "visible": false,
                "skipTaskbar": true,
                "resizable": false,
                "focus": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [
            "sidecar/dist/",
            "sidecar/node_modules/@anthropic-ai/",
            "sidecar/node_modules/@openai/"
        ],
        "windows": {
            "wix": {
                "template": "wix/main.wxs"
            }
        }
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2Mjg0MzUzOTZBM0ZFOUYKUldTZi9xT1dVME1vOW5iekpXWURhbldyQkgvNk5EeGE2SzNlbHhTcWhoK0ZGMUlpeUhMZDlCTXAK",
            "endpoints": [
                "https://github.com/iSirux/OpenWhisperer/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
